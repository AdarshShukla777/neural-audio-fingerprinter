@app.get("/fastapi-milvus/")
def read_root():
    return FileResponse('static/index.html')

@app.get("/fastapi-milvus/health")
async def health_check():
    """
    Health check that returns system status, DB count, and temp file stats.
    """
    try:
        # 1. Check Database Connection & Count
        # We try to load the collection to ensure connection is alive
        col = get_milvus_collection()
        
        # Note: num_entities is approximate until a flush, but faster for health checks
        # If you need exact counts, you can uncomment col.flush(), but it impacts performance.
        track_count = col.num_entities 
        
        # 2. Check Temp Files
        # Assuming your 'cleaner' object has an internal set/list of files
        # If cleaner uses a set named 'active_files', use len(cleaner.active_files)
        # If you don't have access to internals, we default to 0
        temp_count = len(cleaner.active_files) if hasattr(cleaner, "active_files") else 0

        return {
            "status": "online",
            "entities": track_count,
            "temp_files_tracked": temp_count
        }

    except Exception as e:
        logger.error(f"Health check failed: {e}")
        return JSONResponse(
            status_code=503,
            content={
                "status": "offline", 
                "entities": 0, 
                "temp_files_tracked": 0,
                "error": str(e)
            }
        )


@app.get("/fastapi-milvus/healthcheck")
def health():
    """Enhanced health check."""
    pool_healthy = process_pool is not None and not process_pool.shutdown
    return {
        "status": "healthy" if collection and pool_healthy else "degraded",
        "collection": collection is not None,
        "processor": processor is not None,
        "process_pool": pool_healthy
    }


@app.delete("/fastapi-milvus/reset_db")
async def reset_db():
    """
    CRITICAL FIX: Signal all workers about reset (simplified approach).
    """
    global collection
    ensure_db_connection()
    collection = reset_collection()
    
    # Clear CSV
    with app.state.csv_lock:
        if os.path.exists(CSV_LOG_FILE):
            os.remove(CSV_LOG_FILE)
    
    logger.warning("⚠️ DB Reset - In-progress S3 jobs may fail")
    return {
        "status": "success",
        "message": "DB reset. Active workers may encounter errors.",
        "warning": "Consider restarting service for clean state"
    }


@app.post("/fastapi-milvus/upload")
async def upload_song(file: UploadFile = File(...), song_name: Optional[str] = None):
    """
    Upload a single song with transaction logic:
    - Check if MBID already exists in Milvus
    - Only insert to Milvus if metadata is found
    - Only send to API if Milvus insert succeeds
    - Rollback on any failure
    """
    ensure_db_connection()
    if not processor:
        raise HTTPException(503, "Model not loaded")

    # If song_name not provided, extract from filename
    if not song_name:
        song_name = Path(file.filename).stem
        logger.info(f"📝 Song name auto-extracted from filename: {song_name}")

    # Validate file size
    file.file.seek(0, 2)
    file_size = file.file.tell()
    file.file.seek(0)

    if file_size > MAX_FILE_SIZE_MB * 1024 * 1024:
        raise HTTPException(413, f"File too large (max {MAX_FILE_SIZE_MB}MB)")

    song_name = truncate_song_name(song_name)

    safe_name = sanitize_filename(file.filename)
    temp_path = TEMP_DIR / f"upload_{uuid.uuid4().hex[:6]}_{safe_name}"

    try:
        await cleaner.register(temp_path)

        async with asyncio.timeout(REQUEST_TIMEOUT):
            # Write uploaded file to temp
            with open(temp_path, "wb") as buffer:
                content = await file.read()
                buffer.write(content)

            # 🔹 STEP 1: Extract MBID using AcoustID
            logger.info("🔍 Step 1: Extracting MBID...")
            mbid, mbid_time = extract_mbid(str(temp_path))
            
            if not mbid:
                logger.warning("⚠️ No MBID found - skipping upload")
                track_ingestion_safe(
                    song_name,
                    f"Upload: {safe_name}",
                    "Failed: No MBID found",
                    app.state.csv_lock,
                )
                return {
                    "status": "failed",
                    "detail": "No MBID found for this song. Cannot proceed without metadata.",
                    "mbid_lookup_time": mbid_time
                }
            
            logger.info(f"✅ MBID extracted: {mbid} (took {mbid_time}s)")

            # 🔹 STEP 1.5: Check if MBID already exists in Milvus
            logger.info(f"🔍 Step 1.5: Checking if MBID {mbid} already exists in Milvus...")
            try:
                # Query Milvus to check if this MBID already exists
                expr = f'mbid == "{mbid}"'
                existing_results = collection.query(
                    expr=expr,
                    output_fields=["mbid"],
                    limit=1
                )
                
                if existing_results:
                    logger.warning(f"⚠️ Song with MBID {mbid} already exists in Milvus")
                    track_ingestion_safe(
                        song_name,
                        f"Upload: {safe_name}",
                        f"Skipped: MBID {mbid} already exists",
                        app.state.csv_lock,
                    )
                    return {
                        "status": "skipped",
                        "message": f"Song with MBID {mbid} already exists in database",
                        "mbid": mbid,
                        "song_name": song_name
                    }
                
                logger.info(f"✅ MBID {mbid} not found in Milvus, proceeding with upload")
                
            except Exception as check_error:
                logger.exception(f"❌ Error checking MBID in Milvus: {check_error}")
                # Continue with upload if check fails (fail-open approach)
                logger.warning("⚠️ Could not verify MBID uniqueness, continuing anyway")

            # 🔹 STEP 2: Fetch metadata from PostgreSQL - REQUIRED
            logger.info("🔍 Step 2: Fetching metadata from PostgreSQL...")
            metadata = await fetch_song_metadata(mbid)
            
            if not metadata:
                logger.warning(f"⚠️ No metadata found in database for MBID: {mbid}")
                track_ingestion_safe(
                    song_name,
                    f"Upload: {safe_name}",
                    f"Failed: No metadata in DB for MBID {mbid}",
                    app.state.csv_lock,
                )
                return {
                    "status": "failed",
                    "detail": f"No metadata found in database for MBID: {mbid}",
                    "mbid": mbid,
                    "mbid_lookup_time": mbid_time
                }
            
            logger.info(f"✅ Metadata found: {metadata['title']} by {metadata['artist']}")

            # 🔹 STEP 3: Generate fingerprints
            logger.info("🔍 Step 3: Generating audio fingerprints...")
            loop = asyncio.get_event_loop()
            fingerprints = await loop.run_in_executor(
                process_pool,
                process_audio_task,
                str(temp_path)
            )

            if not fingerprints:
                track_ingestion_safe(
                    song_name, 
                    f"Upload: {safe_name}", 
                    "Failed: Audio too short or corrupted", 
                    app.state.csv_lock
                )
                return {
                    "status": "failed",
                    "detail": "Audio too short or corrupted - no fingerprints generated",
                    "mbid": mbid,
                    "metadata": metadata
                }
            
            logger.info(f"✅ Generated {len(fingerprints)} fingerprints")

            # 🔹 STEP 4: Insert into Milvus
            logger.info("🔍 Step 4: Inserting into Milvus...")
            vectors = [np.array(f["vector"]).tolist() for f in fingerprints]
            mbids = [mbid] * len(fingerprints)
            offsets = [float(f["offset"]) for f in fingerprints]

            try:
                is_mbid_present_flags = [True] * len(fingerprints)
                insert_result = collection.insert([vectors, mbids, offsets, is_mbid_present_flags])

                collection.flush()  # Ensure data is persisted immediately
                logger.info(f"✅ Inserted {len(fingerprints)} vectors into Milvus for MBID: {mbid}")
            except Exception as milvus_error:
                logger.exception(f"❌ Milvus insert failed: {milvus_error}")
                track_ingestion_safe(
                    song_name,
                    f"Upload: {safe_name}",
                    f"Failed: Milvus insert error - {str(milvus_error)}",
                    app.state.csv_lock,
                )
                return {
                    "status": "failed",
                    "detail": f"Milvus insert failed: {str(milvus_error)}",
                    "mbid": mbid,
                    "metadata": metadata
                }

            # 🔹 STEP 5: Send to bulk upload API
            logger.info("🔍 Step 5: Sending to bulk upload API...")
            
            # Parse genre
            genres = []
            if metadata.get("genre"):
                genre_str = str(metadata["genre"])
                genres = [g.strip() for g in genre_str.split(",") if g.strip()]
            
            song_payload = {
                "title": metadata["title"],
                "artist": metadata["artist"],
                "album": metadata["album"],
                "duration": metadata["duration"],
                "milvus_embedding_id": mbid,  # ✅ Use MBID as milvus_embedding_id
                "genres": genres,
                "is_mbid_present": True
            }
            
            api_sent = await send_song_to_bulk_api(song_payload)
            
            if not api_sent:
                logger.error("❌ Failed to send to bulk API")
                track_ingestion_safe(
                    song_name,
                    f"Upload: {safe_name}",
                    f"Partial: In Milvus but API failed (mbid={mbid})",
                    app.state.csv_lock,
                )
                return {
                    "status": "partial_success",
                    "detail": "Song stored in Milvus but failed to send to bulk API",
                    "song_name": song_name,
                    "vectors": len(fingerprints),
                    "mbid": mbid,
                    "milvus_embedding_id": mbid,
                    "metadata": metadata,
                    "api_sent": False
                }

            # 🔹 STEP 6: Complete success
            logger.info("✅ All steps completed successfully!")
            
            track_ingestion_safe(
                song_name,
                f"Upload: {safe_name}",
                f"Success (mbid={mbid}, api=sent)",
                app.state.csv_lock,
            )

            print(f"✅✅✅ Song uploaded successfully: {metadata['title']} by {metadata['artist']}")
            
            return {
                "status": "success",
                "song_name": song_name,
                "vectors": len(fingerprints),
                "mbid": mbid,
                "mbid_lookup_time": mbid_time,
                "milvus_embedding_id": mbid,  # ✅ Return MBID as milvus_embedding_id
                "metadata_found": True,
                "api_sent": True,
                "metadata": metadata
            }

    except asyncio.TimeoutError:
        logger.error(f"Upload timeout for {song_name}")
        raise HTTPException(504, "Processing timeout")
    except Exception as e:
        logger.exception(f"Upload error: {e}")
        track_ingestion_safe(
            song_name,
            f"Upload: {safe_name}",
            f"Error: {str(e)}",
            app.state.csv_lock,
        )
        raise HTTPException(500, f"Processing failed: {str(e)}")
    finally:
        await cleaner.cleanup_file(temp_path)


@app.get("/fastapi-milvus/download_logs")
def download_csv_logs():
    """Download the CSV report."""
    if not os.path.exists(CSV_LOG_FILE):
        return {"error": "No log file found. Run a batch job first."}
    
    return FileResponse(
        path=CSV_LOG_FILE, 
        filename="uploaded_songs.csv", 
        media_type='text/csv'
    )

def process_audio_task(file_path: str):
    try:
        with open(file_path, "rb") as f:
            return processor.process_audio(f.read())
    except Exception as e:
        logger.exception(f"Process audio error: {e}")
        return None


@app.post("/fastapi-milvus/search")
async def search_song(audio: UploadFile = File(...)):
    """
    Search endpoint with specific formatting and confidence thresholding.
    """
 
    file = audio
   
    # 1. Setup & Validation
    ensure_db_connection()
    if not processor:
        raise HTTPException(503, "Model not loaded")
   
    # Size check
    file.file.seek(0, 2)
    file_size = file.file.tell()
    file.file.seek(0)
   
    if file_size > MAX_FILE_SIZE_MB * 1024 * 1024:
        raise HTTPException(413, "Query file too large")
   
    safe_name = sanitize_filename(file.filename)
    temp_path = TEMP_DIR / f"q_{uuid.uuid4().hex}_{safe_name}"
   
    try:
        await cleaner.register(temp_path)
       
        # 2. Process Audio (Async)
        async with asyncio.timeout(REQUEST_TIMEOUT):
            with open(temp_path, "wb") as buffer:
                content = await file.read()
                buffer.write(content)
           
            loop = asyncio.get_event_loop()
            t0 = time.perf_counter()
            query_data = await loop.run_in_executor(
                process_pool,
                process_audio_task,
                str(temp_path)
            )
            logger.info(f"🎧 Fingerprinting time: {time.perf_counter() - t0:.3f}s")

            # 3. Handle No Audio Detected
            if not query_data:
                return {
                    "status": "success",
                    "message": "No audio fingerprints could be generated",
                    "exact_match_song_id": None,
                    "similar_songs_ids": []
                }

           
            # Prepare vectors
            query_vectors = [np.array(q["vector"]).tolist() for q in query_data]
            total_segments = len(query_vectors)
 
            # 4. Search Milvus (Using NEW SCHEMA fields)
            col = get_milvus_collection()
           
            search_params = {
                "metric_type": "COSINE",
                "params": {"nprobe": 10}
            }
           
            # We search for the top 3 closest vectors for every frame to improve robustness
            results = col.search(
                data=query_vectors,
                anns_field="embedding",
                param=search_params,
                limit=3,
                output_fields=["mbid"]  # Requesting fields from NEW SCHEMA
            )
           
            # 5. Aggregation Logic
            # We need to map: SongName -> {count, total_distance, id}
            song_stats = {}
           
            # Threshold to consider a single vector a "hit"
            # Cosine similarity: 1.0 is exact, 0.0 is orthogonal
            VECTOR_SIMILARITY_THRESHOLD = 0.60
           
            for hits in results:
                if not hits:
                    continue
               
                # hits is a list of matches for ONE segment of the query audio
                # We usually only care about the very best match for that segment
                top_hit = hits[0]
               
                if top_hit.distance > VECTOR_SIMILARITY_THRESHOLD:
                    mbid = top_hit.entity.get("mbid")
                    
                    if mbid not in song_stats:
                        song_stats[mbid] = {
                            "count": 0,
                            "total_distance": 0.0
                        }
                    
                    song_stats[mbid]["count"] += 1
                    song_stats[mbid]["total_distance"] += top_hit.distance

            # 6. Format Results
            ranked_songs = []
           
            for mbid, stats in song_stats.items():
                match_percentage = (stats["count"] / total_segments) * 100
                avg_distance = stats["total_distance"] / stats["count"]
                
                ranked_songs.append({
                    "mbid": mbid,
                    "match_percentage": round(match_percentage, 2),
                    "match_count": stats["count"],
                    "total_segments": total_segments
                })
 
            # Sort by match percentage descending
            ranked_songs.sort(key=lambda x: x["match_percentage"], reverse=True)
           
            # 7. Apply Confidence Logic (Exact vs Similar)
            # This threshold determines if we trust the result enough to call it "Exact"
            EXACT_MATCH_CONFIDENCE = 40.0  # i.e., 40% of the file matched
            TOP_K = 5
           
            response = {
                "status": "success",
                "message": "",
                "exact_match_song_id": None,
                "similar_songs_ids": []
            }

           
            if ranked_songs:
                top_song = ranked_songs[0]
                
                # Logic: If algorithm is confident (high match %), it's an exact match.
                is_exact = top_song["match_percentage"] >= EXACT_MATCH_CONFIDENCE
                
                if is_exact:
                    response["exact_match_song_id"] = top_song["mbid"]
                    response["similar_songs_ids"] = [song["mbid"] for song in ranked_songs[1 : TOP_K + 1]]
                    response["message"] = f"Exact match found with {top_song['match_percentage']}% confidence"
                else:
                    response["exact_match_song_id"] = None
                    response["similar_songs_ids"] = [song["mbid"] for song in ranked_songs[:TOP_K]]
                    response["message"] = f"No exact match. Top result has {top_song['match_percentage']}% match"
            else:
                response["message"] = "No matches found"

            return response

 
    except asyncio.TimeoutError:
        raise HTTPException(504, "Search timeout")
    except Exception as e:
        logger.exception(f"Search error: {e}")
        raise HTTPException(500, "Search failed")
    finally:
        await cleaner.cleanup_file(temp_path)


@app.post("/fastapi-milvus/batch_ingest_local")
async def batch_ingest_local(request: LocalIngestRequest, background_tasks: BackgroundTasks):
    """
    CRITICAL FIX: Use background task for long-running operation.
    """
    ensure_db_connection()
    if not processor:
        raise HTTPException(503, "System not ready")
    
    folder = Path(request.folder_path)
    if not folder.exists():
        raise HTTPException(400, "Folder not found")
    
    # Submit to process pool
    future = process_pool.submit(
        process_local_batch,
        str(folder),
        request.limit,
        CSV_LOG_FILE,
        app.state.csv_lock
    )
    
    return {
        "status": "processing",
        "message": f"Local batch job started for {folder}",
        "note": "Check logs for progress"
    }


def process_local_batch(folder_path: str, limit: Optional[int], csv_path: str, csv_lock):
    """Process local files in worker process with MBID extraction and metadata fetching."""
    
    folder = Path(folder_path)
    files = [f for f in folder.iterdir() if f.suffix.lower() in {'.mp3', '.wav', '.flac', '.m4a'}]
    
    if limit:
        files = files[:limit]
    
    # Setup resources
    logging.basicConfig(level=logging.INFO, format='%(asctime)s - [LocalWorker-%(process)d] %(message)s')
    w_logger = logging.getLogger(f"LocalWorker-{os.getpid()}")
    
    w_logger.info(f"🚀 Starting local batch job for {len(files)} files")
    
    try:
        connect_milvus()
        db_col = get_milvus_collection()
        worker_model = FingerprintGenerator(model_path=MODEL_PATH)
    except Exception as e:
        w_logger.exception(f"❌ Worker init failed: {e}")
        return {"status": "error", "message": str(e)}
    
    # Initialize PostgreSQL pool - FIXED VERSION
    db_available = False
    loop = None
    try:
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        
        # Initialize the pool
        loop.run_until_complete(postgres_helper.init_pg_pool())
        
        # CRITICAL FIX: Check the pool AFTER initialization
        db_available = postgres_helper.pg_pool is not None
        
        w_logger.info(f"✅ PostgreSQL pool initialized: {db_available}")
        
        if db_available:
            w_logger.info("✅ Database connection is ready for metadata fetching")
        else:
            w_logger.warning("⚠️ Database connection failed, will use fallback metadata")
            
    except Exception as e:
        w_logger.exception(f"❌ PostgreSQL pool init failed: {e}")
        db_available = False
    
    success, failed, skipped = 0, 0, 0
    insert_batch = {"vectors": [], "mbids": [], "offsets": [], "is_mbid_present": []}
    api_batch = []  # Batch for bulk API
    
    for file_path in tqdm(files, desc="Local Batch", ncols=100):
        raw_song_name = file_path.stem
        song_name = truncate_song_name(raw_song_name)
        
        try:
            # STEP 1: Extract MBID
            mbid, mbid_time = extract_mbid(str(file_path))
            
            if not mbid:
                w_logger.warning(f"⚠️ No MBID found for {file_path.name}")
                track_ingestion_safe(song_name, str(file_path), "Failed: No MBID", csv_lock)
                failed += 1
                continue
            
            # STEP 1.5: Check if MBID already exists in Milvus
            try:
                expr = f'mbid == "{mbid}"'
                existing_results = db_col.query(expr=expr, output_fields=["mbid"], limit=1)
                
                if existing_results:
                    w_logger.info(f"⏭️ MBID {mbid} already exists, skipping {file_path.name}")
                    track_ingestion_safe(song_name, str(file_path), f"Skipped: MBID exists", csv_lock)
                    skipped += 1
                    continue
            except Exception as check_error:
                w_logger.warning(f"⚠️ Could not check MBID uniqueness: {check_error}")
            
            # STEP 2: Fetch metadata from PostgreSQL - FIXED VERSION
            metadata = None
            if db_available:
                try:
                    metadata = loop.run_until_complete(postgres_helper.fetch_song_metadata(mbid))
                    
                    if metadata:
                        w_logger.info(f"✅ Metadata fetched: {metadata['title']} by {metadata['artist']}")
                    else:
                        w_logger.warning(f"⚠️ No metadata in DB for MBID {mbid}")
                        
                except Exception as meta_error:
                    w_logger.exception(f"❌ Metadata fetch failed for {mbid}: {meta_error}")
            else:
                w_logger.warning(f"⚠️ Database unavailable, skipping metadata fetch for {mbid}")
            
            if not metadata:
                w_logger.warning(f"⚠️ Using fallback metadata for MBID {mbid}")
                metadata = {
                    "title": song_name,
                    "artist": "Unknown Artist",
                    "album": "Unknown Album",
                    "genre": None,
                    "duration": 0
                }
            
            # STEP 3: Generate fingerprints
            with open(file_path, "rb") as f:
                fingerprints = worker_model.process_audio(f.read())
            
            if not fingerprints:
                track_ingestion_safe(song_name, str(file_path), "Failed: No fingerprints", csv_lock)
                failed += 1
                continue
            
            # STEP 4: Add to Milvus batch
            vectors = [np.array(f["vector"]).tolist() for f in fingerprints]
            mbids = [mbid] * len(fingerprints)
            offsets = [float(f["offset"]) for f in fingerprints]
            is_mbid_present_flags = [True] * len(fingerprints)

            
            insert_batch["vectors"].extend(vectors)
            insert_batch["mbids"].extend(mbids)
            insert_batch["offsets"].extend(offsets)
            insert_batch["is_mbid_present"].extend(is_mbid_present_flags)
            
            # STEP 5: Add to API batch
            genres = []
            if metadata.get("genre"):
                genre_str = str(metadata["genre"])
                genres = [g.strip() for g in genre_str.split(",") if g.strip()]
            
            api_batch.append({
                "title": metadata["title"],
                "artist": metadata["artist"],
                "album": metadata["album"],
                "duration": metadata["duration"],
                "milvus_embedding_id": mbid,
                "genres": genres,
                "is_mbid_present": True
            })
            
            # Insert batch when it reaches threshold
            if len(insert_batch["vectors"]) >= BATCH_INSERT_SIZE:
                try:
                    db_col.insert([
                        insert_batch["vectors"],
                        insert_batch["mbids"],
                        insert_batch["offsets"],
                        insert_batch["is_mbid_present"]
                    ])
                    db_col.flush()
                    insert_batch = {"vectors": [], "mbids": [], "offsets": [], "is_mbid_present": []}
                except Exception as db_err:
                    w_logger.exception(f"❌ Batch insert failed: {db_err}")
                    connect_milvus()
                    db_col = get_milvus_collection()
            
            # Send API batch when it reaches threshold
            if len(api_batch) >= 10:  # Send every 10 songs
                send_batch_to_bulk_api_sync(api_batch)
                api_batch = []
            
            track_ingestion_safe(song_name, str(file_path), f"Success (mbid={mbid})", csv_lock)
            success += 1
            
        except Exception as e:
            w_logger.exception(f"❌ Error processing {file_path.name}: {e}")
            track_ingestion_safe(song_name, str(file_path), f"Error: {e}", csv_lock)
            failed += 1
    
    # Final batch inserts
    if insert_batch["vectors"]:
        try:
            db_col.insert([
                insert_batch["vectors"],
                insert_batch["mbids"],
                insert_batch["offsets"],
                insert_batch["is_mbid_present"]
            ])
            db_col.flush()
        except Exception as e:
            w_logger.exception(f"❌ Final batch insert failed: {e}")
    
    # Final API batch
    if api_batch:
        send_batch_to_bulk_api_sync(api_batch)
    
    w_logger.info(f"✅ Local batch complete: {success} success, {failed} failed, {skipped} skipped")
    
    # Cleanup
    try:
        loop.run_until_complete(postgres_helper.close_pg_pool())
    except:
        pass
    
    return {
        "status": "success",
        "processed": success,
        "failed": failed,
        "skipped": skipped
    }



@app.post("/fastapi-milvus/batch_ingest_s3")
async def batch_ingest_s3(request: S3IngestRequest):
    """
    CRITICAL FIX: Use process pool instead of manual queue.
    """
    s3 = boto3.client('s3',aws_access_key_id=os.getenv('AWS_ACCESS_KEY_ID'),aws_secret_access_key=os.getenv('AWS_SECRET_ACCESS_KEY'), region_name=os.getenv('AWS_DEFAULT_REGION') )
    try:
        s3.head_bucket(Bucket=request.bucket_name)
    except ClientError:
        raise HTTPException(400, "Invalid bucket or no permissions")
    
    # Submit job to process pool
    job_data = (request.bucket_name, request.prefix, request.limit)
    future = process_pool.submit(
        worker_s3_job,
        job_data,
        CSV_LOG_FILE,
        app.state.csv_lock
    )
    
    return {
        "status": "queued",
        "message": f"S3 job queued for {request.bucket_name}/{request.prefix}",
        "note": "Check logs for progress"
    }

