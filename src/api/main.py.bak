@app.get("/fastapi-milvus/test_metadata/{mbid}")
async def test_metadata_fetch(mbid: str):
    """Test metadata fetch for a specific MBID."""
    
    if not pg_pool:
        return {
            "error": "PostgreSQL pool not initialized",
            "pool_status": "not_initialized"
        }
    
    try:
        metadata = await fetch_song_metadata(mbid)
        
        if metadata:
            return {
                "status": "success",
                "mbid": mbid,
                "metadata": metadata,
                "pool_status": "connected"
            }
        else:
            return {
                "status": "not_found",
                "mbid": mbid,
                "message": "No metadata found in database",
                "pool_status": "connected"
            }
    except Exception as e:
        return {
            "status": "error",
            "mbid": mbid,
            "error": str(e),
            "error_type": type(e).__name__
        }

@app.get("/fastapi-milvus/stats")
async def get_milvus_stats(mbid: Optional[str] = None):
    """
    Get Milvus statistics or specific song info by MBID.
    
    - No query params: Returns total songs count and vectors
    - With ?mbid=xxx: Returns specific song details from Milvus only
    """
    ensure_db_connection()
    
    try:
        # Case 1: Get specific song by MBID
        if mbid:
            expr = f'mbid == "{mbid}"'
            results = collection.query(
                expr=expr,
                output_fields=["mbid", "offsets", "is_mbid_present"],
                limit=10000
            )
            
            if not results:
                raise HTTPException(404, f"MBID '{mbid}' not found")
            
            offsets = sorted([float(r.get("offsets", 0)) for r in results])
            
            return {
                "mbid": mbid,
                "vector_count": len(results),
                "is_mbid_present": results[0].get("is_mbid_present", False),
                "offsets": {
                    "min": offsets[0] if offsets else 0,
                    "max": offsets[-1] if offsets else 0,
                    "sample": offsets[:10]
                }
            }
        
        # Case 2: Get overall statistics
        total_vectors = collection.num_entities
        
        # Count unique MBIDs
        all_mbids = set()
        offset = 0
        
        while True:
            results = collection.query(
                expr="mbid != ''",
                output_fields=["mbid"],
                limit=1000,
                offset=offset
            )
            
            if not results:
                break
            
            all_mbids.update(r.get("mbid") for r in results if r.get("mbid"))
            
            if len(results) < 1000:
                break
            
            offset += 1000
        
        unique_songs = len(all_mbids)
        
        return {
            "total_unique_songs": unique_songs,
            "total_vectors": total_vectors,
            "avg_vectors_per_song": round(total_vectors / unique_songs, 2) if unique_songs > 0 else 0
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.exception(f"❌ Stats error: {e}")
        raise HTTPException(500, str(e))

@app.post("/fastapi-milvus/upload-songs-to-s3/")
async def ingest_music(request: BulkRequestUploadS3, background_tasks: BackgroundTasks):
    """
    Starts a background job to download 'N' songs, upload to S3, 
    and log results to the 'wazzdat' schema.
    """
    try:
        # --- 1. ROBUST INPUT VALIDATION ---
        # Prevent zero or negative counts
        if request.song_count <= 0:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST, 
                detail="Song count must be greater than 0."
            )

        # Prevent overly large batches that could choke the server
        if request.song_count > 10000:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST, 
                detail="Please limit batches to 10000 songs."
            )

        # Prevent empty or whitespace-only S3 strings
        if not request.s3_bucket_name.strip() or not request.s3_folder_name.strip():
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST, 
                detail="S3 bucket and folder names cannot be empty."
            )

        # --- 2. QUEUE THE JOB ---
        # We log this action so we have a trace ID or timestamp of WHEN it was requested
        logger.info(f"Queuing bulk job for {request.song_count} songs to {request.s3_bucket_name}")
        
        background_tasks.add_task(upload_bulk_songs_to_s3_job, request)
        
        return {
            "message": "Bulk ingestion started",
            "target_count": request.song_count,
            "s3_bucket": request.s3_bucket_name,
            "s3_folder": request.s3_folder_name,
            "note": "Check database 'wazzdat.s3_downloads_log' for progress."
        }

    # Catch validation errors we just raised so they pass through cleanly
    except HTTPException as he:
        raise he

    # Catch any unexpected system errors (e.g., BackgroundTasks fails)
    except Exception as e:
        logger.error(f"CRITICAL: Failed to queue bulk job: {str(e)}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR, 
            detail="Failed to initialize background job."
        )

class ReconcileRequest(BaseModel):
    s3_bucket_name: str
    s3_folder_name: str

@app.post("/fastapi-milvus/reconcile-s3-db")
async def reconcile_data(req: ReconcileRequest):
    """
    Scans S3 bucket for songs that are missing in the Database 
    and restores their entries automatically.
    """
    # This might take time, so we await it (or use background tasks if very large)
    result = await reconcile_s3_db_job(req.s3_bucket_name, req.s3_folder_name)
    
    return {
        "message": "Reconciliation completed",
        "details": result
    }

