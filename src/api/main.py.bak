class CleanupManager:
    """Manages temporary files with proper exception handling."""
    def __init__(self):
        self.files: Set[Path] = set()
        self._lock = asyncio.Lock()
    
    async def register(self, path: Path):
        async with self._lock:
            self.files.add(path)
    
    async def cleanup_file(self, path: Path):
        async with self._lock:
            try:
                if path.exists():
                    path.unlink()
            except Exception as e:
                logger.error(f"Cleanup error for {path}: {e}")
            finally:
                self.files.discard(path)  # Always remove from tracking
    
    async def cleanup_all(self):
        for path in list(self.files):
            await self.cleanup_file(path)


cleaner = CleanupManager()


def sanitize_filename(filename: str) -> str:
    path = Path(filename)
    clean_stem = re.sub(r'[^\w\-\. ]', '', path.stem)
    clean_stem = clean_stem.replace(' ', '_')
    return f"{clean_stem or 'audio'}{path.suffix.lower()}"


def truncate_song_name(name: str, max_len: int = MAX_SONG_NAME_LENGTH) -> str:
    """Truncate song name safely."""
    if not isinstance(name, str):
        name = str(name)
    if len(name) <= max_len:
        return name
    return name[:max_len]


def load_existing_songs_unsafe(csv_path: str) -> Set[str]:
    """
    Load without lock - used by worker process on startup.
    CRITICAL FIX: Load once, not on every file.
    """
    processed = set()
    if not os.path.exists(csv_path):
        return processed
    
    try:
        with open(csv_path, mode='r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                if row.get("Status") == "Success":
                    song_name = truncate_song_name(row.get("Song Name", ""))
                    processed.add(song_name)
    except Exception as e:
        logger.error(f"Error reading CSV: {e}")
    return processed


def track_ingestion_safe(song_name: str, source: str, status: str, lock):
    """Process-safe CSV writing with lock."""
    song_name = truncate_song_name(song_name)
    file_exists = os.path.isfile(CSV_LOG_FILE)
    
    try:
        with lock:
            with open(CSV_LOG_FILE, mode='a', newline='', encoding='utf-8') as f:
                writer = csv.writer(f)
                if not file_exists:
                    writer.writerow(["Song Name", "Source", "Status"])
                writer.writerow([song_name, source, status])
    except Exception as e:
        logger.exception(f"Failed to log {song_name}: {e}")


def ensure_db_connection():
    """Enhanced connection validation."""
    global collection
    if collection is None:
        logger.warning("⚠️ Collection ref is None. Reconnecting...")
        try:
            connect_milvus()
            collection = get_milvus_collection()
            logger.info("✅ Reconnected!")
        except Exception as e:
            logger.exception(f"❌ DB Connect Failed: {e}")
            raise HTTPException(503, "Database unavailable")

USE_ACOUSTID = os.getenv("USE_ACOUSTID", "true").lower() == "true"
 
MBID_REGEX = re.compile(
    r"^[0-9a-fA-F]{8}-"
    r"[0-9a-fA-F]{4}-"
    r"[0-9a-fA-F]{4}-"
    r"[0-9a-fA-F]{4}-"
    r"[0-9a-fA-F]{12}$"
)
 
def extract_mbid_from_filename(key: str) -> str | None:
    """
    Extract MBID from filename like <mbid>.wav
    """
    stem = Path(key).stem.strip()
    if MBID_REGEX.match(stem):
        return stem.lower()
    return None

def worker_s3_job(job_data: tuple, csv_path: str, csv_lock):
    """
    S3 worker with MBID extraction, metadata fetching, and bulk API sending.
    """
    bucket, prefix, limit = job_data
    
    # Setup logging for this process
    logging.basicConfig(level=logging.INFO, format='%(asctime)s - [S3Worker-%(process)d] %(message)s')
    w_logger = logging.getLogger(f"S3Worker-{os.getpid()}")
    
    w_logger.info(f"🚀 Starting S3 job: s3://{bucket}/{prefix}")
    
    try:
        connect_milvus()
        db_col = get_milvus_collection()
        worker_model = FingerprintGenerator(model_path=MODEL_PATH)
        s3 = boto3.client('s3')
    except Exception as e:
        w_logger.exception(f"❌ Worker init failed: {e}")
        return {"status": "error", "message": str(e)}
    
    db_available = False
    loop = None
    try:
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        
        loop.run_until_complete(postgres_helper.init_pg_pool())
        
        db_available = postgres_helper.pg_pool is not None
        
        w_logger.info(f"✅ PostgreSQL pool initialized: {db_available}")
        
        if db_available:
            w_logger.info("✅ Database connection is ready for metadata fetching")
        else:
            w_logger.warning("⚠️ Database connection failed, will use fallback metadata")
            
    except Exception as e:
        w_logger.exception(f"❌ PostgreSQL pool init failed: {e}")
        db_available = False
    
    # List S3 objects
    try:
        paginator = s3.get_paginator('list_objects_v2')
        page_iterator = paginator.paginate(Bucket=bucket, Prefix=prefix)
    except ClientError as e:
        w_logger.exception(f"S3 access error: {e}")
        return {"status": "error", "message": "S3 access denied"}
    
    all_keys = []
    try:
        for page in page_iterator:
            if "Contents" not in page:
                continue
            for obj in page["Contents"]:
                key = obj["Key"]
                if key.lower().endswith(('.mp3', '.wav', '.flac', '.m4a')):
                    all_keys.append(key)
    except Exception as e:
        w_logger.exception(f"S3 pagination error: {e}")
        return {"status": "error", "message": "S3 pagination failed"}
    
    w_logger.info(f"Found Total {len(all_keys)} audio files in S3")
    
    success_count, failed_count, skipped_count = 0, 0, 0
    insert_batch = {"vectors": [], "mbids": [], "offsets": [], "is_mbid_present": []}
    api_batch = []
    
    pbar_total = limit if limit else len(all_keys)
    pbar = tqdm(total=pbar_total, desc=f"S3Worker-{os.getpid()}", ncols=100)

    for key in all_keys:
        if limit and success_count >= limit:
            w_logger.info(f"🎯 Ingestion limit reached ({limit} new songs). Stopping.")
            break
        raw_song_name = Path(key).stem
        song_name = truncate_song_name(raw_song_name)
        
        safe_name = sanitize_filename(key)
        local_path = TEMP_DIR / f"s3worker_{uuid.uuid4().hex}_{safe_name}"
        
        # ===== EARLY MBID CHECK (BEFORE DOWNLOAD) =====
        mbid = None
        mbid_time = None

        if not USE_ACOUSTID:
            mbid = extract_mbid_from_filename(key)

            if mbid:
                try:
                    expr = f'mbid == "{mbid}"'
                    existing_results = db_col.query(
                        expr=expr,
                        output_fields=["mbid"],
                        limit=1
                    )

                    if existing_results:
                        w_logger.info(
                            f"⏭️ MBID {mbid} already exists, skipping download for {key}"
                        )
                        track_ingestion_safe(
                            song_name,
                            f"s3://{bucket}/{key}",
                            "Skipped: MBID exists",
                            csv_lock
                        )
                        skipped_count += 1
                        continue

                except Exception as check_error:
                    w_logger.warning(
                        f"⚠️ Early MBID check failed for {key}: {check_error}"
                    )

        
        try:
            # Download file
            s3.download_file(bucket, key, str(local_path))
            
            # Check file size
            file_size_mb = local_path.stat().st_size / (1024 * 1024)
            if file_size_mb > MAX_FILE_SIZE_MB:
                w_logger.warning(f"File too large: {key} ({file_size_mb:.1f}MB)")
                track_ingestion_safe(song_name, key, "Failed: Too Large", csv_lock)
                failed_count += 1
                continue
            
            # STEP 1: Extract MBID
            mbid = None
            mbid_time = None
 
            if not USE_ACOUSTID:
                mbid = extract_mbid_from_filename(key)
 
                if mbid:
                    w_logger.info(f"✅ MBID extracted from filename: {mbid}")
                else:
                    w_logger.warning(f"⚠️ Invalid or missing MBID in filename: {key}")
 
            if USE_ACOUSTID and not mbid:
                mbid, mbid_time = extract_mbid(str(local_path))
 
                if mbid:
                    w_logger.info(f"✅ MBID extracted via AcoustID: {mbid}")
            
            if not mbid:
                w_logger.warning(f"⚠️ No MBID found for {key}")
                track_ingestion_safe(song_name, f"s3://{bucket}/{key}", "Failed: No MBID", csv_lock)
                failed_count += 1
                continue
            
            # STEP 2: Fetch metadata - FIXED VERSION
            metadata = None
            if db_available:
                try:
                    metadata = loop.run_until_complete(postgres_helper.fetch_song_metadata(mbid))
                    
                    if metadata:
                        w_logger.info(f"✅ Metadata fetched: {metadata['title']} by {metadata['artist']}")
                    else:
                        w_logger.warning(f"⚠️ No metadata in DB for MBID {mbid}")
                        
                except Exception as meta_error:
                    w_logger.exception(f"❌ Metadata fetch failed for {mbid}: {meta_error}")
            else:
                w_logger.warning(f"⚠️ Database unavailable, skipping metadata fetch for {mbid}")
            
            if not metadata:
                w_logger.warning(f"⚠️ Using fallback metadata for MBID {mbid}")
                metadata = {
                    "title": song_name,
                    "artist": "Unknown Artist",
                    "album": "Unknown Album",
                    "genre": None,
                    "duration": 0
                }
            
            # STEP 3: Generate fingerprints
            with open(local_path, "rb") as f:
                audio_data = f.read()
            
            fingerprints = worker_model.process_audio(audio_data)
            
            if not fingerprints:
                track_ingestion_safe(song_name, f"s3://{bucket}/{key}", "Failed: No Fingerprints", csv_lock)
                failed_count += 1
                continue
            
            # STEP 4: Add to Milvus batch
            vectors = [np.array(f["vector"]).tolist() for f in fingerprints]
            mbids = [mbid] * len(fingerprints)
            offsets = [float(f["offset"]) for f in fingerprints]
            is_mbid_present_flags = [True] * len(fingerprints)

            insert_batch["vectors"].extend(vectors)
            insert_batch["mbids"].extend(mbids)
            insert_batch["offsets"].extend(offsets)
            insert_batch["is_mbid_present"].extend(is_mbid_present_flags)
            
            # STEP 5: Add to API batch
            genres = []
            if metadata.get("genre"):
                genre_str = str(metadata["genre"])
                genres = [g.strip() for g in genre_str.split(",") if g.strip()]
            
            api_batch.append({
                "title": metadata["title"],
                "artist": metadata["artist"],
                "album": metadata["album"],
                "duration": metadata["duration"],
                "milvus_embedding_id": mbid,
                "genres": genres,
                "is_mbid_present": True
            })
            
            # Batch insert
            if len(insert_batch["vectors"]) >= BATCH_INSERT_SIZE:
                try:
                    db_col.insert([
                        insert_batch["vectors"],
                        insert_batch["mbids"],
                        insert_batch["offsets"],
                        insert_batch["is_mbid_present"]
                    ])
                    db_col.flush()
                    insert_batch = {"vectors": [], "mbids": [], "offsets": [], "is_mbid_present": []}
                except Exception as db_err:
                    w_logger.exception(f"❌ Batch insert failed: {db_err}")
                    connect_milvus()
                    db_col = get_milvus_collection()
            
            # Send API batch
            if len(api_batch) >= 10:
                send_batch_to_bulk_api_sync(api_batch)
                api_batch = []
            
            track_ingestion_safe(song_name, f"s3://{bucket}/{key}", f"Success (mbid={mbid})", csv_lock)
            success_count += 1
            pbar.update(1)
        
        except Exception as e:
            w_logger.exception(f"Error processing {key}: {e}")
            track_ingestion_safe(song_name, f"s3://{bucket}/{key}", f"Error: {str(e)}", csv_lock)
            failed_count += 1
        
        finally:
            if local_path.exists():
                local_path.unlink()
    pbar.close()
    # Final batch inserts
    if insert_batch["vectors"]:
        try:
            db_col.insert([
                insert_batch["vectors"],
                insert_batch["mbids"],
                insert_batch["offsets"],
                insert_batch["is_mbid_present"]
            ])
            db_col.flush()
        except Exception as e:
            w_logger.exception(f"Final batch insert failed: {e}")
    
    # Final API batch
    if api_batch:
        send_batch_to_bulk_api_sync(api_batch)
    
    w_logger.info(f"✅ S3 job complete: {success_count} success, {failed_count} failed, {skipped_count} skipped")
    
    # Cleanup
    try:
        loop.run_until_complete(postgres_helper.close_pg_pool())
    except:
        pass
    
    return {
        "status": "success",
        "processed": success_count,
        "failed": failed_count,
        "skipped": skipped_count
    }

# ==========================================
# 4. LIFESPAN (PROPER RESOURCE MANAGEMENT)
# ==========================================
@asynccontextmanager
async def lifespan(app: FastAPI):
    """
    CRITICAL FIX: Proper initialization and cleanup of all resources.
    """
    global collection, processor, process_pool, manager
    
    logger.info("🟢 SYSTEM STARTUP")
    
    # 1. Initialize Manager (CRITICAL FIX)
    manager = mp_context.Manager()
    csv_lock = manager.Lock()
    app.state.csv_lock = csv_lock
    
    # 2. Initialize Main Process Resources
    try:
        connect_milvus()
        collection = get_milvus_collection()
        processor = FingerprintGenerator(model_path=MODEL_PATH)
        logger.info("✅ Main Process Ready")
    except Exception as e:
        logger.exception(f"❌ Main Init Failed: {e}")
    
    # 3. Initialize Process Pool
    process_pool = ProcessPoolExecutor(
        max_workers=2,
        mp_context=mp_context
    )
    app.state.process_pool = process_pool
    
    # 4. NEW: Initialize PostgreSQL connection pool
    try:
        await init_pg_pool()
    except Exception as e:
        logger.exception(f"❌ PostgreSQL pool init failed: {e}")
    
    yield
    
    # 5. SHUTDOWN
    logger.info("🔴 SHUTDOWN INITIATED")
    
    # Shutdown process pool
    if process_pool:
        logger.info("Shutting down process pool...")
        process_pool.shutdown(wait=True, cancel_futures=True)
        logger.info("✅ Process pool shut down")
    
    # Shutdown manager
    if manager:
        logger.info("Shutting down manager...")
        manager.shutdown()
        logger.info("✅ Manager shut down")
    
    # NEW: Close PostgreSQL pool
    await close_pg_pool()
    
    # Cleanup temp files
    await cleaner.cleanup_all()
    logger.info("✅ Cleanup complete")


app = FastAPI(title="Neural Audio Search", lifespan=lifespan)
app.mount("/static", StaticFiles(directory="static"), name="static")


class S3IngestRequest(BaseModel):
    bucket_name: str
    prefix: str = ""
    limit: Optional[int] = 50


class LocalIngestRequest(BaseModel):
    folder_path: str
    limit: Optional[int] = 50


