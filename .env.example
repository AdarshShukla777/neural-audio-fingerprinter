# ============================================
# NoiseAudioSearch Environment Configuration
# Copy this file to neural_network_fingerprinter/src/.env and fill in values
# ============================================

# ============================================
# TENSORFLOW
# ============================================
TF_ENABLE_ONEDNN_OPTS=0

# ============================================
# MILVUS VECTOR DATABASE
# ============================================
# Local dev: localhost | Docker: milvus-standalone-nnfp
MILVUS_HOST=localhost
MILVUS_PORT=19530
COLLECTION_NAME=audio_fingerprints_32bit_float

# ============================================
# ML MODEL
# ============================================
MODEL_PATH=exported_model
USE_ACOUSTID=false

# ============================================
# DATABASE CONNECTION MODE
# Priority: USE_LOCAL_PG > USE_SSH_TUNNEL > DIRECT
# ============================================
USE_SSH_TUNNEL=true
SSH_TUNNEL_URL=ssh://user:password@ssh-host:22

DATABASE_URL=postgresql://user:password@localhost:5433/dbname
REMOTE_DATABASE_URL=postgresql://user:password@rds-host:5432/dbname
LOCAL_PORT=5433

USE_LOCAL_PG=false
LOCAL_PG_URL=

# ============================================
# AWS S3
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ============================================
# EXTERNAL APIS
# ============================================
ACOUSTID_API_KEY=
BULK_UPLOAD_API_URL=
